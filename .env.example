# Tailscale - chave de autenticação para o Funnel
TS_AUTHKEY=tskey-auth-xxxxx

# GitLab - secret do webhook (header x-gitlab-token)
GITLAB_SECRET=seu-secret-gitlab

# GitLab - token de acesso para API (comentários nas issues e glab CLI)
GITLAB_TOKEN=glpat-xxxxx

# GitHub - secret do webhook (validação HMAC SHA256)
GITHUB_WEBHOOK_SECRET=seu-secret-github

# GitHub - token de acesso para API (comentários nas issues e gh CLI)
GITHUB_TOKEN=ghp_xxxxx

# Claude Code - token OAuth para autenticação
CLAUDE_CODE_OAUTH_TOKEN=seu-token-oauth

# Usuários autorizados a acionar o agente (separados por vírgula)
ALLOWED_USERS=usuario1,usuario2
